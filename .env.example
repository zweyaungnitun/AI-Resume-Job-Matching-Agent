# ========================================
# BACKEND ENVIRONMENT VARIABLES
# ========================================

# Application Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Google APIs
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_google_search_engine_id_here

# Gemini API (via LangChain)
GEMINI_MODEL=gemini-1.5-flash

# Pinecone Vector DB
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=job-matcher
PINECONE_ENVIRONMENT=production

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google OAuth (For Resume Upload)
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret

# Database (Optional - for future user management)
DATABASE_URL=postgresql://user:password@localhost:5432/job_matcher

# CORS
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# ========================================
# FRONTEND ENVIRONMENT VARIABLES
# ========================================

# API Configuration
VITE_API_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
